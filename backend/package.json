{
  "name": "starbucks-backend",
  "version": "1.0.0",
  "description": "Starbucks Cup E-commerce Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:low-memory": "node --max-old-space-size=512 --optimize-for-size dist/index.js",
    "db:migrate": "npx --yes sequelize-cli db:migrate --env production",
    "db:migrate:undo": "npx --yes sequelize-cli db:migrate:undo --env production",
    "db:migrate:status": "npx --yes sequelize-cli db:migrate:status --env production",
    "sync-meilisearch": "ts-node src/scripts/sync-meilisearch.ts",
    "test-meilisearch": "ts-node src/test-meilisearch.ts"
  },
  "keywords": [
    "starbucks",
    "ecommerce",
    "api",
    "typescript",
    "express"
  ],
  "author": "Starbucks Shop Team",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "aws-sdk": "^2.1692.0",
    "bcryptjs": "^3.0.2",
    "connect-redis": "^9.0.0",
    "connect-session-sequelize": "^7.1.7",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "express-session": "^1.18.1",
    "googleapis": "^161.0.0",
    "helmet": "^8.1.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "meilisearch": "^0.55.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.15.1",
    "pg": "^8.19.0",
    "pg-hstore": "^2.3.4",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.11.0",
    "sequelize": "^6.37.7",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.9.0",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^10.0.0",
    "sequelize-cli": "^6.6.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2"
  }
}
