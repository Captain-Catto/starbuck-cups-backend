# Copy this file to .env and update with your actual values
# Production target: Frontend https://hasron.vn + API https://api.hasron.vn

# Environment Configuration
NODE_ENV=production
PORT=8080
TRUST_PROXY=1
INCLUDE_LOCAL_ORIGINS=false
DB_SYNC_ON_START=false
SESSION_STORE_SYNC_ON_START=false

# Database
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/starbucks_shop"
DB_SSL=false

# JWT
JWT_SECRET="replace-with-a-long-random-session-secret"
JWT_ACCESS_SECRET="replace-with-a-long-random-access-secret"
JWT_REFRESH_SECRET="replace-with-a-long-random-refresh-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"
EXPOSE_REFRESH_TOKEN=false

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_BLOCK_DURATION_MS=900000
AUTH_RATE_LIMIT_STORE=redis
REDIS_URL="redis://127.0.0.1:6379"
ALLOW_IN_MEMORY_RATE_LIMIT=false
REQUEST_LOG_ENABLED=false
SOCKET_LOG_ENABLED=false

# CORS
FRONTEND_URL="https://hasron.vn"
ALLOWED_ORIGINS="https://hasron.vn,https://www.hasron.vn"

# Cookies (API subdomain auth)
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=".hasron.vn"

# MeiliSearch
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_MASTER_KEY="replace-meilisearch-master-key"

# Messenger Platform
MESSENGER_PAGE_ACCESS_TOKEN=""
MESSENGER_APP_SECRET=""
MESSENGER_VERIFY_TOKEN=""

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH="uploads/"

# API Documentation
API_DOCS_ENABLED=true
API_DOCS_PATH="/docs"
