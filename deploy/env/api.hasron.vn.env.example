# Backend production env for https://api.hasron.vn

NODE_ENV=production
PORT=8080
TRUST_PROXY=1
INCLUDE_LOCAL_ORIGINS=false
DB_SYNC_ON_START=false
SESSION_STORE_SYNC_ON_START=false

# Database
DATABASE_URL=postgresql://postgres:change-password@127.0.0.1:5432/starbucks_shop
DB_SSL=false

# JWT / Sessions
JWT_SECRET=replace-with-long-random-session-secret
JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
EXPOSE_REFRESH_TOKEN=false

# CORS
FRONTEND_URL=https://hasron.vn
ALLOWED_ORIGINS=https://hasron.vn,https://www.hasron.vn

# Cookies for hasron.vn <-> api.hasron.vn auth/session flows
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=.hasron.vn

# Security / limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_BLOCK_DURATION_MS=900000
AUTH_RATE_LIMIT_STORE=redis
REDIS_URL=redis://127.0.0.1:6379
ALLOW_IN_MEMORY_RATE_LIMIT=false
REQUEST_LOG_ENABLED=false
SOCKET_LOG_ENABLED=false
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads/

# API docs
API_DOCS_ENABLED=true
API_DOCS_PATH=/docs

# Search
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_MASTER_KEY=replace-meilisearch-master-key

# Optional integrations
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_APP_SECRET=
MESSENGER_VERIFY_TOKEN=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=
