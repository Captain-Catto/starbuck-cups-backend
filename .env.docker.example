MEILI_MASTER_KEY=change-this-meili-master-key

JWT_SECRET=change-this-session-secret
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
EXPOSE_REFRESH_TOKEN=false
AUTH_RATE_LIMIT_STORE=redis
REDIS_URL=redis://redis:6379
ALLOW_IN_MEMORY_RATE_LIMIT=false
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_BLOCK_DURATION_MS=900000

FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
TRUST_PROXY=0
INCLUDE_LOCAL_ORIGINS=true
DB_SYNC_ON_START=true
SESSION_STORE_SYNC_ON_START=true
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
REQUEST_LOG_ENABLED=true
SOCKET_LOG_ENABLED=true

GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=
